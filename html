<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Poisar - Mumbai Neighborhood</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f8fafc; display: flex; justify-content: center; padding: 20px; }
        .neighborhood-card { background: white; width: 450px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); border-top: 6px solid #d97706; overflow: hidden; }
        .header { background: #fffbeb; padding: 20px; text-align: center; border-bottom: 1px solid #fde68a; }
        .content { padding: 25px; line-height: 1.6; color: #334155; }
        .label { font-weight: bold; color: #b45309; }
        .metro-pill { background: #fef3c7; color: #92400e; padding: 2px 8px; border-radius: 4px; font-weight: bold; font-size: 0.85em; }
    </style>
</head>
<body>
    <div class="neighborhood-card">
        <div class="header"><h1>📍 Poisar</h1><p>Kandivali, Mumbai</p></div>
        <div class="content">
            <p><span class="label">Affiliation:</span> Part of Kandivali (West)</p>
            <p><span class="label">Metro Connectivity:</span> <span class="metro-pill">Metro Line 2A</span></p>
            <p><span class="label">Primary Landmark:</span> Poisar Gymkhana / Poisar River</p>
            <p><span class="label">Railway Link:</span> Near Kandivali Station (KILE)</p>
            <p><span class="label">Pincode:</span> 400067</p>
        </div>
    </div>
</body>
</html>
